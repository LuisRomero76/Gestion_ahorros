# ==============================================
# ARCHIVO DE EJEMPLO - PLANTILLA SIN VALORES REALES
# ==============================================
# Copia este archivo como .env si necesitas configuraciones personalizadas
#
# NOTA: En Flutter, las variables de entorno no se cargan automáticamente
# como en Node.js. Para usarlas necesitarías:
# - flutter_dotenv package, o
# - Compilar con --dart-define
# ==============================================

# Firebase Configuration (PÚBLICO - solo para referencia)
# Estos valores YA están en firebase_options.dart
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app

# API Keys (PÚBLICO - solo para referencia)
# Las API Keys de Firebase para apps cliente son PÚBLICAS
# La seguridad se maneja con Firestore Rules y Firebase Auth
FIREBASE_WEB_API_KEY=AIzaSy...tu_web_api_key
FIREBASE_ANDROID_API_KEY=AIzaSy...tu_android_api_key
FIREBASE_IOS_API_KEY=AIzaSy...tu_ios_api_key

# Cloud Functions (SI USAS EMULADORES LOCALES)
# FUNCTIONS_EMULATOR_HOST=localhost:5001

# ==============================================
# IMPORTANTE - Seguridad
# ==============================================
# ✅ SEGURO subir al repo:
#    - .env.example (este archivo con placeholders)
#    - firebase_options.dart (API Keys públicas de cliente)
#    - .firebaserc (nombre del proyecto)
#
# ⚠️ NUNCA subir al repo:
#    - .env (si tiene valores reales personalizados)
#    - Service Account Keys (.json de admin)
#    - Private keys (.p12, .pem)
#    - Tokens de servidor o secretos del backend
#
# 📚 Más info sobre API Keys públicas:
#    https://firebase.google.com/docs/projects/api-keys
