# ==============================================
# Firebase
# ==============================================
# Archivos de configuración local de Firebase
.firebase/

# Service Account Keys (MUY IMPORTANTE - NUNCA SUBIR)
**/serviceAccountKey.json
**/service-account*.json
**/*-firebase-adminsdk-*.json

# Firebase Hosting cache
.firebase/

# Firebase Emulator data
firebase-debug.log
firestore-debug.log
ui-debug.log

# ==============================================
# Variables de Entorno
# ==============================================
# Archivo real con variables de entorno (si decides usarlo)
.env
.env.local
.env.*.local

# Mantener el ejemplo
!.env.example

# ==============================================
# Firebase - Google Services (OPCIONAL)
# ==============================================
# IMPORTANTE: Algunos desarrolladores suben estos archivos al repo
# porque son configuraciones públicas de Firebase.
# Otros prefieren no subirlos por precaución.
#
# Firebase recomienda: ESTÁ BIEN subirlos (son públicos)
# Pero si prefieres no hacerlo, descomenta las siguientes líneas:

# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist
# macos/Runner/GoogleService-Info.plist

# ==============================================
# Cloud Functions
# ==============================================
# Node modules de Cloud Functions
functions/node_modules/
functions/.runtimeconfig.json
functions/lib/

# Logs de funciones
functions/firebase-debug.log
functions/firestore-debug.log
functions/ui-debug.log

# Service account keys para funciones (MUY IMPORTANTE)
functions/*-service-account*.json
functions/serviceAccountKey.json

